# ============================================================
# frontend-user - Variables de entorno
# ============================================================

# === DESARROLLO LOCAL (copiar como .env) ===
VITE_API_URL=http://localhost:8080
VITE_WS_URL=ws://localhost:8080/ws
VITE_BACKEND_URL=http://localhost:8080

# === PRODUCCIÓN (configurar en Vercel) ===
# Solo necesitas crear VITE_WS_URL en Vercel:
# VITE_WS_URL=wss://tienda-backend-latest-h8ht.onrender.com/ws
# VITE_API_URL y VITE_BACKEND_URL no son necesarios (Vercel proxy lo maneja)
