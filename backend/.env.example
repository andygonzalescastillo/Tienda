# ============================================================
# backend - Variables de entorno
# Copia este archivo como .env y ajusta los valores
# ============================================================

# ============================================================
# DESARROLLO LOCAL CON DOCKER (recomendado)
# ============================================================
# Docker Compose ya tiene defaults (postgres/postgres/db)
# Si quieres valores diferentes, descomenta y cambia:
#
# DB_URL=jdbc:postgresql://localhost:5432/tienda_db
# DB_NAME=tienda_db
# DB_USER=postgres
# DB_PASSWORD=postgres

# Para probar emails reales (Brevo):
# EMAIL_USERNAME=tu_email@gmail.com
# EMAIL_PASSWORD=tu_api_key_brevo

# Para probar OAuth (login social):
# GOOGLE_CLIENT_ID=tu_id
# GOOGLE_CLIENT_SECRET=tu_secret

# ============================================================
# PRODUCCIÓN (Render) - Variables obligatorias
# ============================================================

# SPRING_PROFILES_ACTIVE=prod

# --- Base de Datos (Supabase / PostgreSQL externo) ---
# DB_URL=jdbc:postgresql://host:5432/postgres?sslmode=require&prepareThreshold=0
# DB_USER=tu_usuario
# DB_PASSWORD=tu_password

# --- Redis (Upstash) ---
# REDIS_HOST=tu-host.upstash.io
# REDIS_PASSWORD=tu_password
# REDIS_SSL=true

# --- Seguridad ---
# JWT_SECRET=genera_una_clave_de_al_menos_64_caracteres
# COOKIE_SECURE=true

# --- Correo (Brevo) ---
# EMAIL_USERNAME=tu_email@gmail.com
# EMAIL_PASSWORD=tu_api_key_brevo

# --- Frontend URLs ---
# FRONTEND_URL=https://tu-frontend.vercel.app
# FRONTEND_ADMIN_URL=https://tu-admin.vercel.app
# OAUTH_REDIRECT_BASE_URL=https://tu-frontend.vercel.app

# --- OAuth2 ---
# GOOGLE_CLIENT_ID=...
# GOOGLE_CLIENT_SECRET=...
# MICROSOFT_CLIENT_ID=...
# MICROSOFT_CLIENT_SECRET=...
# FACEBOOK_APP_ID=...
# FACEBOOK_APP_SECRET=...
# GITHUB_CLIENT_ID=...
# GITHUB_CLIENT_SECRET=...
